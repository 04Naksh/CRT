// problem no 1 
// print no 1 to 5, 5 times

#include <iostream>
using namespace std;


int main(){
    for(int i = 1; i<= 5; i++){
        for(int j = 1; j <= 5;  j++){
            cout << j;
            
        }
        cout<<"\n";    
    }
}
