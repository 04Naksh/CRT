\\using while loop print 1 to 10
#include<iostream>
using namespace std;
int main(){
    int i=1;
    while(i<=10){
        cout<<i<<endl;
        i++;
    }
    return 0;
        
    }
\\ using do while print 1 to 10\\
#include<iostream>
using namespace std;
int main(){
    int i=1;
    do{
        cout<<i<<endl;
        i++;
    }while(i<=10);
        
    
}
//using factorial of a number//
#include<iostream>
using namespace std;
int main(){
    int num;
    cout<<"enter the number";
    cin>>num;
    for(int i=num;i>=1;i--){
        cout<<i<<"*";
    }
    
    
}
