/// using a for loop print digits 1to 10;#include<iostream>
using namespace std;
int main(){
    for(int i=1;i<=10;i++){
        cout<<"value of i "<<i<<endl;
        
    }
    return 0;
}
\\using for loop print even number
#include<iostream>
using namespace std;
int main(){
    for(int i=2;i<=10;i+=2){
        cout<<"value of i "<<i<<endl;
        
    }
    return 0;
}
\\using while loop print 1 to 10
#include<iostream>
using namespace std;
int main(){
    int i=1;
    while(i<=10){
        cout<<i<<endl;
        i++;
    }
    return 0;
        
